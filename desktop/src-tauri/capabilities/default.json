{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities — local-only chat app, no network or filesystem access from the webview.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "core:path:default",
    "core:window:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/llama-mtmd-cli",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
